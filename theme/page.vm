        ## =============================================
        ## CONTENT PAGE LAYOUT
        ## =============================================

            ## Determine if this is a section page (has children) or a leaf page
            #set($pageChildren = $page.children)
            #set($isSectionPage = ($pageChildren && $pageChildren.size() > 0))

            <div class="content-layout">
                <nav class="breadcrumb" aria-label="Breadcrumb">
                    ## Build ancestor chain (up to 5 levels)
                    #set($crumbs = [])
                    #set($walker = $page.parent)
                    #if($walker)#set($void = $crumbs.add(0, $walker))#end
                    #if($walker && $walker.parent)#set($walker = $walker.parent)#set($void = $crumbs.add(0, $walker))#end
                    #if($walker && $walker.parent)#set($walker = $walker.parent)#set($void = $crumbs.add(0, $walker))#end
                    #if($walker && $walker.parent)#set($walker = $walker.parent)#set($void = $crumbs.add(0, $walker))#end
                    #if($walker && $walker.parent)#set($walker = $walker.parent)#set($void = $crumbs.add(0, $walker))#end

                    #foreach($crumb in $crumbs)
                        <a href="$crumb.absoluteLink" class="breadcrumb-link">
                            #if($foreach.first)
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                            #end
                            $crumb.title
                        </a>
                        <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    #end
                    <span class="breadcrumb-current">$page.title</span>
                </nav>

                <div class="content-columns">
                    <article class="article">
                        <h1 class="article-title">$page.title</h1>
                        <div class="article-meta">
                            #if($page.lastModificationDate)
                                <span class="article-meta-item article-date" data-raw-date="$page.lastModificationDate">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                    <span class="article-date-text">Last updated</span>
                                </span>
                            #end
                            ## Version badge — reads from Confluence page label matching "version-*"
                            #foreach($label in $page.labels)
                                #if($label.name.startsWith("version-"))
                                    <span class="version-badge">${label.name.replace("version-", "v")}</span>
                                #end
                            #end
                        </div>
                        #if($page.content && $page.content.toString().trim().length() > 0)
                        <div class="content-body">
                            $page.content
                        </div>
                        #end

                            ## For section pages, render a list of child pages
                            #if($isSectionPage)
                                <div class="section-children">
                                    <p>This section contains the following pages:</p>
                                    <div class="section-children-grid">
                                        #foreach($childPage in $pageChildren)
                                            <a href="$childPage.absoluteLink" class="section-child-card">
                                                <span class="section-child-title">$childPage.title</span>
                                                <span class="section-child-arrow">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                                </span>
                                            </a>
                                        #end
                                    </div>
                                </div>
                            #end

                            ## "Was this helpful?" feedback widget — always at the bottom
                            <div class="page-feedback" id="pageFeedback">
                                <div class="pf-question">
                                    <span class="pf-label">Was this page helpful?</span>
                                    <div class="pf-buttons">
                                        <button class="pf-btn pf-btn-yes" data-vote="yes" aria-label="Yes, helpful">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                                            Yes
                                        </button>
                                        <button class="pf-btn pf-btn-no" data-vote="no" aria-label="No, not helpful">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h3a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2h-3"/></svg>
                                            No
                                        </button>
                                    </div>
                                </div>
                                <div class="pf-form" id="pfForm" style="display:none;">
                                    <textarea class="pf-textarea" id="pfComment" placeholder="Any suggestions for improvement? (optional)" rows="3"></textarea>
                                    <div class="pf-form-actions">
                                        <button class="pf-submit" id="pfSubmit">Send Feedback</button>
                                        <button class="pf-skip" id="pfSkip">Skip</button>
                                    </div>
                                </div>
                                <div class="pf-thanks" id="pfThanks" style="display:none;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                    <span>Thank you for your feedback!</span>
                                </div>
                            </div>
                    </article>

                    ## Sidebar: show children for section pages, siblings for leaf pages
                    #if($isSectionPage)
                        <aside class="sidebar">
                            <div class="sidebar-inner">
                                <h4 class="sidebar-title">$page.title</h4>
                                <ul class="sidebar-nav">
                                    #foreach($childPage in $pageChildren)
                                        <li>
                                            <a href="$childPage.absoluteLink" class="sidebar-link">$childPage.title</a>
                                        </li>
                                    #end
                                </ul>
                            </div>
                        </aside>
                    #elseif($page.parent && $page.parent.children && $page.parent.children.size() > 1)
                        <aside class="sidebar">
                            <div class="sidebar-inner">
                                <h4 class="sidebar-title">$page.parent.title</h4>
                                <ul class="sidebar-nav">
                                    #foreach($sibling in $page.parent.children)
                                        <li>
                                            <a href="$sibling.absoluteLink" class="sidebar-link #if($page.title == $sibling.title)sidebar-active#end">$sibling.title</a>
                                        </li>
                                    #end
                                </ul>
                            </div>
                        </aside>
                    #end
                </div>
            </div>

        #end
    </main>

