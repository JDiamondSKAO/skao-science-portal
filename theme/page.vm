<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="robots" content="index,follow">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=5.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="generator" content="Created with Scroll Viewport - K15t">

    <script>
        var contextPath = '$contextPath';
        ## $page.space.key may not exist in all Viewport versions — fallback to SPK
        #if($page.space && $page.space.key)
            var spaceKey = '$page.space.key';
        #else
            var spaceKey = 'SPK';
        #end
    </script>

    ## Resolve the viewport root (home) page by walking up the page tree
    #set($homePage = $page)
    #if($homePage.parent)#set($homePage = $homePage.parent)#end
    #if($homePage.parent)#set($homePage = $homePage.parent)#end
    #if($homePage.parent)#set($homePage = $homePage.parent)#end
    #if($homePage.parent)#set($homePage = $homePage.parent)#end
    #set($homeLink = $homePage.absoluteLink)

    $webPanels
    $page.resources.meta
    $page.resources.js
    $page.resources.css
    $page.resources.requireForContext('viewcontent')
    $page.resources.require('com.atlassian.confluence.plugins.confluence-inline-tasks:inline-tasks-styles')

    <title>$page.title — SKAO Science Operations Portal</title>

    ## OpenGraph / social meta tags for link previews
    <meta property="og:title" content="$page.title — SKAO Science Operations Portal" />
    <meta property="og:description" content="The central hub for SKAO science operations — documentation, tools, proposals, and community resources for the world's largest radio telescope." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="${theme.baseUrl}/images/og-image.jpg" />
    <meta property="og:site_name" content="SKAO Science Operations Portal" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="$page.title — SKAO Science Operations Portal" />
    <meta name="twitter:description" content="Documentation, tools, and resources for the SKAO science community." />
    <meta name="twitter:image" content="${theme.baseUrl}/images/og-image.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="${theme.baseUrl}/css/style.css">
    <link rel="stylesheet" href="${theme.baseUrl}/css/eggs.css">

    ## Matter.js for interactive 404 page — only load when needed
    #set($checkTitle = $page.title.toLowerCase().trim())
    #if($checkTitle == "not found" || $checkTitle == "page not found" || $checkTitle == "404")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.19.0/matter.min.js" defer></script>
    #end

    ## Prevent flash of wrong theme — runs before body renders
    <script>
        (function(){try{if(localStorage.getItem('skao-theme')==='dark'){document.documentElement.classList.add('dark')}}catch(e){}})();
    </script>
</head>

<body>

    ## SKIP-TO-CONTENT (WCAG 2.1 AA)
    <a href="#main-content" class="skip-to-content">Skip to main content</a>

    ## =============================================
    ## SEARCH MODAL OVERLAY
    ## =============================================
    <div class="search-modal" id="searchModal">
        <div class="search-modal-backdrop" id="searchModalBackdrop"></div>
        <div class="search-modal-dialog">
            <div class="search-modal-header">
                <div class="search-modal-input-wrap">
                    <svg class="search-modal-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <form id="searchForm" action="${contextPath}/plugins/scroll-viewport/search" method="GET" style="flex:1;" onsubmit="return false;">
                        <input type="text" name="q" id="searchModalInput" placeholder="Search documentation..." class="search-modal-field" autocomplete="off" />
                    </form>
                    <button class="search-modal-close" id="searchModalClose" aria-label="Close search">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>
            </div>
            <div class="search-modal-body" id="searchModalBody">
                <div class="search-modal-empty" id="searchEmpty">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--slate-300);margin-bottom:16px;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <p style="color:var(--slate-500);">Start typing to search documentation...</p>
                    <p style="font-size:13px;color:var(--slate-400);margin-top:8px;">Search by title, category, or keywords</p>
                </div>
                <div class="search-modal-loading" id="searchLoading" style="display:none;">
                    <p style="color:var(--slate-500);text-align:center;padding:24px 0;">Searching...</p>
                </div>
                <div class="search-modal-results" id="searchResults" style="display:none;"></div>
                <div class="search-modal-no-results" id="searchNoResults" style="display:none;">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--slate-300);margin-bottom:16px;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <p style="color:var(--slate-500);">No results found</p>
                    <p style="font-size:13px;color:var(--slate-400);margin-top:8px;">Try different keywords or check your spelling</p>
                </div>
            </div>
            <div class="search-modal-footer">
                <div class="search-kbd-hints">
                    <span class="kbd-hint"><kbd>↵</kbd> to search</span>
                    <span class="kbd-hint"><kbd>Esc</kbd> to close</span>
                </div>
            </div>
        </div>
    </div>

    ## SLIDE-OUT SIDEBAR removed — backup in BACKUP-navigate-sidebar.vm

    ## =============================================
    ## HEADER
    ## =============================================
    <header class="skao-header">
        <div class="header-bg" style="background-image: url('${theme.baseUrl}/images/header-bg.jpg');"></div>
        <div class="header-overlay"></div>
        <div class="header-content">
            <div class="header-top">
                <div class="header-inner">
                    <a href="$homeLink" class="brand-link">
                        <img src="${theme.baseUrl}/images/skao-logo-white.png" alt="SKAO" class="logo-img">
                        <div class="brand-title">
                            <span class="site-title">Science Operations Portal</span>
                            <span class="site-subtitle">Square Kilometre Array Observatory</span>
                        </div>
                    </a>
                    <div class="header-actions">
                        <button class="header-search-btn" id="openSearchModal" aria-label="Search documentation">
                            <span class="header-search-text">Search documentation...</span>
                            <span class="header-search-right">
                                <kbd class="header-kbd">Ctrl+K</kbd>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                            </span>
                        </button>
                        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode" title="Toggle dark mode">
                            <svg class="theme-icon-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                            <svg class="theme-icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                        </button>
                        <button class="mobile-search-btn" id="openSearchModalMobile" aria-label="Search">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                        </button>
                        <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Open menu">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                        </button>
                    </div>
                </div>
            </div>
            <nav class="header-nav" id="headerNav">
                <div class="header-inner">
                    <ul class="nav-list">
                        <li><a href="$homeLink" class="nav-link">Home</a></li>
                        ## Always show root-level sections in the header nav
                        #set($rootChildren = $homePage.children)
                        #if($rootChildren && $rootChildren.size() > 0)
                            #foreach($navItem in $rootChildren)
                                <li><a href="$navItem.absoluteLink" class="nav-link #if($page.title == $navItem.title)nav-active#end">$navItem.title</a></li>
                            #end
                        #end
                    </ul>
                </div>
            </nav>
        </div>
    </header>

    ## =============================================
    ## ANNOUNCEMENT BANNER
    ## =============================================
    <div class="announcement-banner" id="announcementBanner">
        <div class="announcement-inner">
            <div class="announcement-content">
                <svg class="announcement-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                <p class="announcement-text">
                    Welcome to the SKAO Science Operations Portal — documentation is being migrated. Check back regularly for updates.
                </p>
            </div>
            <button class="announcement-close" aria-label="Dismiss">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
    </div>

    ## =============================================
    ## OBSERVATORY STATUS STRIP
    ## =============================================
    <div class="status-strip">
        <div class="status-strip-inner">
            <span class="status-strip-label">Observatory Status</span>
            <div class="status-strip-items">
                <a href="https://www.skao.int/en/explore/telescopes/ska-mid" target="_blank" rel="noopener" class="status-item">
                    <span class="status-dot status-amber"></span>
                    <span class="status-name">SKA-Mid</span>
                    <span class="status-state">Commissioning</span>
                </a>
                <a href="https://www.skao.int/en/explore/telescopes/ska-low" target="_blank" rel="noopener" class="status-item">
                    <span class="status-dot status-grey"></span>
                    <span class="status-name">SKA-Low</span>
                    <span class="status-state">Construction</span>
                </a>
                <a href="https://www.srcnet.org" target="_blank" rel="noopener" class="status-item">
                    <span class="status-dot status-blue"></span>
                    <span class="status-name">SRCNet</span>
                    <span class="status-state">Beta</span>
                </a>
            </div>
        </div>
    </div>

    ## =============================================
    ## MAIN CONTENT
    ## =============================================
    <main class="skao-main" id="main-content">

        #set($children = $page.children)
        #set($isHomePage = (!$page.parent))

        ## =============================================
        ## 404 DETECTION — Viewport routes errors through page.vm
        ## Detect by title "Not Found" with no children (not the real homepage)
        ## =============================================
        #set($pageTitle = $page.title.toLowerCase().trim())
        #set($is404 = false)
        #if($pageTitle == "not found" || $pageTitle == "page not found" || $pageTitle == "404")
            #set($is404 = true)
        #end

        #if($is404)
        ## =============================================
        ## 404 ERROR PAGE — Interactive physics-based
        ## Matter.js loaded in <head> only for 404 pages
        ## =============================================
            <div class="nf-container" id="notFoundContainer">
                <canvas class="nf-canvas" id="nfCanvas"></canvas>
                <div class="nf-content">
                    <h1 class="nf-title">404</h1>
                    <p class="nf-subtitle">Page Not Found</p>
                    <p class="nf-text">The page you're looking for has drifted into the cosmic void.</p>
                    <div class="nf-actions">
                        <a href="$homeLink" class="nf-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                            Return to Portal
                        </a>
                        <a href="https://jira.skatelescope.org/servicedesk" target="_blank" rel="noopener" class="nf-btn nf-btn-outline">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            Report an Issue
                        </a>
                    </div>
                </div>
            </div>

        #elseif($isHomePage && $children && $children.size() > 0)
        ## =============================================
        ## HOMEPAGE LAYOUT (only for the root page)
        ## =============================================

            ## HERO (collapsible)
            <section class="hero" id="heroSection">
                <div class="hero-content">
                    <div class="hero-inner">
                        <h1 class="hero-title">$page.title</h1>
                        <p class="hero-desc">
                            Welcome to the SKAO Science Operations Portal. Access comprehensive documentation,
                            tools, and guidance for using the Square Kilometre Array Observatory for your research.
                        </p>
                        <div class="hero-actions">
                            ## Find the Getting Started page dynamically
                            #foreach($heroChild in $children)
                                #set($heroTitle = $heroChild.title.toLowerCase())
                                #if($heroTitle.contains("getting") || $heroTitle.contains("started"))
                                    <a href="$heroChild.absoluteLink" class="btn btn-gradient">Getting Started Guide</a>
                                #end
                            #end
                            <a href="#docs" class="btn btn-outline-white">Browse Documentation</a>
                        </div>
                        <button class="hero-toggle">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"></polyline></svg>
                            Collapse
                        </button>
                    </div>
                </div>
                <div class="hero-collapsed" style="display:none;">
                    <div class="hero-inner">
                        <span>Show welcome</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </div>
                </div>
            </section>

            ## QUICK ACCESS — icons & descriptions matched by page title
            <section class="quick-access" id="docs">
                <div class="section-inner">
                    <h2 class="section-heading">Quick Access</h2>
                    <div class="qa-grid">
                        #foreach($child in $children)
                            #set($t = $child.title.toLowerCase())
                            ## Skip Full Operations sections for now
                            #if(!$t.contains("observ") && !$t.contains("propos"))
                            <a href="$child.absoluteLink" class="qa-card">
                                <div class="qa-icon #if($t.contains('about'))qa-icon-about#elseif($t.contains('getting') || $t.contains('started'))qa-icon-getting#elseif($t.contains('science') || $t.contains('verif'))qa-icon-sv#elseif($t.contains('data'))qa-icon-data#elseif($t.contains('support') || $t.contains('faq'))qa-icon-support#elseif($t.contains('srcnet') || $t.contains('src'))qa-icon-srcnet#elseif($t.contains('tool'))qa-icon-tools#else qa-icon-default#end">
                                    ## About — info circle
                                    #if($t.contains("about"))
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                                    ## Getting Started — compass
                                    #elseif($t.contains("getting") || $t.contains("started"))
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
                                    ## Science Verification — beaker/flask
                                    #elseif($t.contains("science") || $t.contains("verif"))
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6v7l4 8H5l4-8V3z"/><line x1="8" y1="3" x2="16" y2="3"/></svg>
                                    ## Data — database
                                    #elseif($t.contains("data"))
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                                    ## Support — help circle
                                    #elseif($t.contains("support") || $t.contains("faq"))
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                    ## SRCNet — globe
                                    #elseif($t.contains("srcnet") || $t.contains("src"))
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                                    ## Tools — wrench
                                    #elseif($t.contains("tool"))
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                                    ## Default — document
                                    #else
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                    #end
                                </div>
                                <h3 class="qa-title">$child.title</h3>
                                <p class="qa-desc">
                                    #if($t.contains("about"))
                                        Learn about the Observatory
                                    #elseif($t.contains("getting") || $t.contains("started"))
                                        Start observing with SKAO
                                    #elseif($t.contains("science") || $t.contains("verif"))
                                        Early access programme
                                    #elseif($t.contains("data"))
                                        Access observation data
                                    #elseif($t.contains("support") || $t.contains("faq"))
                                        Get help and contact us
                                    #elseif($t.contains("srcnet") || $t.contains("src"))
                                        Regional centre network
                                    #elseif($t.contains("tool"))
                                        Software and pipelines
                                    #else
                                        Browse documentation
                                    #end
                                </p>
                            </a>
                            #end
                        #end
                    </div>
                </div>
            </section>

            ## TOOLS & SERVICES
            <section class="tools-services">
                <div class="section-inner">
                    <h2 class="section-heading">Tools &amp; Services</h2>
                    <div class="ts-grid">
                        <a href="https://sensitivity-calculator.skao.int" target="_blank" rel="noopener" class="ts-card">
                            <div class="ts-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="12" y1="10" x2="14" y2="10"/><line x1="16" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="12" y1="14" x2="14" y2="14"/><line x1="8" y1="18" x2="14" y2="18"/><line x1="16" y1="14" x2="16" y2="18"/></svg>
                            </div>
                            <div class="ts-body">
                                <span class="ts-title">Sensitivity Calculator</span>
                                <span class="ts-desc">Plan your observations and estimate integration times</span>
                            </div>
                            <svg class="ts-ext" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        </a>
                        <a href="https://www.srcnet.org" target="_blank" rel="noopener" class="ts-card">
                            <div class="ts-icon ts-icon-srcnet">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                            </div>
                            <div class="ts-body">
                                <span class="ts-title">SRCNet Portal</span>
                                <span class="ts-desc">Access the SKA Regional Centre network for data processing</span>
                            </div>
